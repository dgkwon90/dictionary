{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "메인 윈도우와 Quick Search 팝업 권한",
  "windows": ["main", "quicksearch"],
  "permissions": [
    "core:default",
    "opener:default",
    "core:window:allow-hide",
    "clipboard-manager:allow-read-text",
    {
      "identifier": "http:default",
      "allow": [{ "url": "http://127.0.0.1:48989/*" }]
    }
  ]
}
